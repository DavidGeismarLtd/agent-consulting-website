<% content_for(:title, "Home") %>

<div class="w-full">
  <!-- Hero Section -->
  <section id="home" class="relative bg-primary-900 text-white py-24 md:py-32 overflow-hidden">
    <!-- Subtle background pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 25%, rgba(59,130,246,0.3) 0%, transparent 50%), radial-gradient(circle at 75% 75%, rgba(96,165,250,0.2) 0%, transparent 50%);"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-accent-400 font-semibold tracking-wider uppercase text-sm mb-4">The Agent Economy Is Here</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-tight">
          Spread the <span class="text-accent-400">Agent Economy</span> to Your Business
        </h1>
        <p class="mt-6 text-lg md:text-xl text-gray-300 leading-relaxed">
          We help businesses understand and implement AI agent automation — identifying your highest-value opportunities and building agents that deliver real results, for free.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href="#contact" class="inline-flex items-center justify-center px-8 py-3 bg-accent-500 hover:bg-accent-600 text-white font-semibold rounded-lg transition-colors duration-200">
            Get Your Free Analysis
          </a>
          <a href="#services" class="inline-flex items-center justify-center px-8 py-3 border-2 border-white/30 hover:border-white/60 text-white font-semibold rounded-lg transition-colors duration-200">
            Learn More
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-primary-900">How We Work With You</h2>
        <p class="mt-4 text-lg text-gray-600">A proven three-step process to bring AI agents into your business — at zero risk.</p>
      </div>
      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1: Free Business Analysis -->
        <div class="p-8 rounded-xl bg-gray-50 hover:shadow-lg transition-shadow duration-300">
          <div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-primary-900">Free Business Analysis</h3>
          <p class="mt-3 text-gray-600">We analyze your business processes to identify the highest-value automation opportunities. No commitment required.</p>
        </div>
        <!-- Card 2: Free Agent v0 -->
        <div class="p-8 rounded-xl bg-gray-50 hover:shadow-lg transition-shadow duration-300">
          <div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-primary-900">Free Agent v0</h3>
          <p class="mt-3 text-gray-600">We build and deploy the first version of your AI agent for your top use case — completely free.</p>
        </div>
        <!-- Card 3: Iterative Optimization -->
        <div class="p-8 rounded-xl bg-gray-50 hover:shadow-lg transition-shadow duration-300">
          <div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-primary-900">Iterative Optimization</h3>
          <p class="mt-3 text-gray-600">We continuously refine and improve your agent based on real-world performance data until it's perfect.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodology Section -->
  <section id="methodology" class="py-20 md:py-28 bg-primary-900 text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold">Our Methodology</h2>
        <p class="mt-4 text-lg text-gray-300">A rock solid, battle-tested methodology that delivers measurable results every time.</p>
      </div>

      <!-- Timeline / Stepper -->
      <div class="mt-16 relative">
        <!-- Connecting line (desktop) -->
        <div class="hidden md:block absolute top-10 left-0 right-0 h-0.5 bg-accent-500/30"></div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8">
          <!-- Step 1: Discovery -->
          <div class="relative text-center">
            <div class="relative z-10 w-20 h-20 bg-accent-500 rounded-full flex items-center justify-center mx-auto text-2xl font-bold shadow-lg shadow-accent-500/25">
              <span>1</span>
            </div>
            <h3 class="mt-6 text-xl font-semibold text-white">Discovery</h3>
            <p class="mt-3 text-gray-400 text-sm leading-relaxed">We conduct a thorough analysis of your business workflows and identify automation opportunities.</p>
          </div>

          <!-- Step 2: Design -->
          <div class="relative text-center">
            <div class="relative z-10 w-20 h-20 bg-accent-500 rounded-full flex items-center justify-center mx-auto text-2xl font-bold shadow-lg shadow-accent-500/25">
              <span>2</span>
            </div>
            <h3 class="mt-6 text-xl font-semibold text-white">Design</h3>
            <p class="mt-3 text-gray-400 text-sm leading-relaxed">We architect the optimal AI agent solution for your highest-value use case.</p>
          </div>

          <!-- Step 3: Deploy -->
          <div class="relative text-center">
            <div class="relative z-10 w-20 h-20 bg-accent-500 rounded-full flex items-center justify-center mx-auto text-2xl font-bold shadow-lg shadow-accent-500/25">
              <span>3</span>
            </div>
            <h3 class="mt-6 text-xl font-semibold text-white">Deploy</h3>
            <p class="mt-3 text-gray-400 text-sm leading-relaxed">We build and launch your agent v0, integrating it into your existing systems.</p>
          </div>

          <!-- Step 4: Optimize -->
          <div class="relative text-center">
            <div class="relative z-10 w-20 h-20 bg-accent-500 rounded-full flex items-center justify-center mx-auto text-2xl font-bold shadow-lg shadow-accent-500/25">
              <span>4</span>
            </div>
            <h3 class="mt-6 text-xl font-semibold text-white">Optimize</h3>
            <p class="mt-3 text-gray-400 text-sm leading-relaxed">We iterate based on real performance data, continuously improving accuracy and efficiency.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section id="team" class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-primary-900">Meet the Founders</h2>
        <p class="mt-4 text-lg text-gray-600">Expert software engineers and ML engineers with extensive experience in agentic development and consulting. We combine deep technical expertise with real-world business acumen.</p>
      </div>

      <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-10 max-w-4xl mx-auto">
        <!-- David Geismar -->
        <div class="bg-gray-50 rounded-2xl p-8 text-center hover:shadow-lg transition-shadow duration-300">
          <div class="w-28 h-28 bg-primary-800 rounded-full mx-auto flex items-center justify-center text-white text-3xl font-bold">DG</div>
          <h3 class="mt-6 text-xl font-bold text-primary-900">David Geismar</h3>
          <p class="text-accent-500 font-medium mt-1">Co-Founder &amp; Expert Software Engineer</p>
          <p class="mt-4 text-gray-600 text-sm leading-relaxed">Seasoned software engineer with deep expertise in building production-grade AI agents and complex automation systems. Passionate about turning cutting-edge AI into reliable business tools.</p>
          <a href="https://www.linkedin.com/in/david-geismar-53bba3a4/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-6 px-5 py-2.5 bg-primary-800 hover:bg-primary-700 text-white text-sm font-medium rounded-lg transition-colors duration-200">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>

        <!-- Aymeric Flaisler -->
        <div class="bg-gray-50 rounded-2xl p-8 text-center hover:shadow-lg transition-shadow duration-300">
          <div class="w-28 h-28 bg-primary-800 rounded-full mx-auto flex items-center justify-center text-white text-3xl font-bold">AF</div>
          <h3 class="mt-6 text-xl font-bold text-primary-900">Aymeric Flaisler</h3>
          <p class="text-accent-500 font-medium mt-1">Co-Founder &amp; ML Engineer / Entrepreneur</p>
          <p class="mt-4 text-gray-600 text-sm leading-relaxed">ML engineer and entrepreneur with hands-on experience designing and deploying intelligent agent systems. Bridges the gap between advanced machine learning research and practical business applications.</p>
          <a href="https://www.linkedin.com/in/aflaisler/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-6 px-5 py-2.5 bg-primary-800 hover:bg-primary-700 text-white text-sm font-medium rounded-lg transition-colors duration-200">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mx-auto">
        <div class="text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-primary-900">Ready to Automate?</h2>
          <p class="mt-4 text-lg text-gray-600">Get a <strong>free analysis</strong> of your highest-value automation opportunity. No commitment, just actionable insights.</p>
        </div>

        <% if flash[:notice] %>
          <div class="mt-8 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800 text-center font-medium">
            <%= flash[:notice] %>
          </div>
        <% end %>

        <%= form_with url: contacts_path, method: :post, class: "mt-10 space-y-6" do |f| %>
          <div>
            <label for="contact_name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
            <input type="text" name="contact[name]" id="contact_name" required
                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none transition-colors duration-200"
                   placeholder="Your name">
          </div>
          <div>
            <label for="contact_email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input type="email" name="contact[email]" id="contact_email" required
                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none transition-colors duration-200"
                   placeholder="you@company.com">
          </div>
          <div>
            <label for="contact_message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
            <textarea name="contact[message]" id="contact_message" rows="4" required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none transition-colors duration-200 resize-y"
                      placeholder="Tell us about your business and what you'd like to automate..."></textarea>
          </div>
          <div class="text-center">
            <button type="submit" class="inline-flex items-center justify-center px-10 py-4 bg-accent-500 hover:bg-accent-600 text-white font-semibold rounded-lg text-lg transition-colors duration-200 shadow-lg shadow-accent-500/25">
              Get Your Free Analysis
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </section>
</div>

